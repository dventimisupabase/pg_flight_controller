# Production profile: at-scale runs (Phase 4 acceleration).
# ~1 hour per trial; 60 windows, 48 after 20% warm-up discard.
# Source this file before invoking run.sh or campaign.sh.
#
# NOTE: Preload sizes (EFFICACY_PRELOAD_ROWS) are not overridden here —
# they fall through to run.sh's per-fixture defaults.  For the real
# at-scale campaign, set EFFICACY_PRELOAD_ROWS explicitly.

export EFFICACY_DURATION=3600
export EFFICACY_SAMPLE_INTERVAL=60
export EFFICACY_PGBENCH_CLIENTS=4
export EFFICACY_PGBENCH_RATE=50
